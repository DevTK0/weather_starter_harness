# This file is a setup checklist, not the deployment source of truth.
# Real Cloudflare Worker secrets should be set with Wrangler:
#   npx wrangler secret put DISCORD_BOT_TOKEN
#   npx wrangler secret put AI_GATEWAY_API_KEY
#   npx wrangler secret put VERCEL_TOKEN
#
# Non-secret runtime config belongs in wrangler.jsonc `vars`.

# Discord app configuration
# DISCORD_BOT_TOKEN is a secret.
# DISCORD_PUBLIC_KEY and DISCORD_APPLICATION_ID are app identifiers and can
# live in wrangler.jsonc later once the Discord webhook slice is implemented.
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# Discord routing
# This will move into wrangler.jsonc vars once the Discord integration exists.
DISCORD_DEMO_CHANNEL_ID=1503650966908440638

# Model provider used by Flue
# AI_GATEWAY_API_KEY is a secret.
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh
FLUE_MODEL=anthropic/claude-sonnet-4-6

# Vercel Sandbox / API access
# VERCEL_TOKEN is a secret used by the future orchestrator to reach Vercel.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Demo target repository
DEMO_REPO_URL=https://github.com/AISG-AIAP/weather_starter.git
DEMO_PROJECT_PATH=/workspace/weather_starter

# Vercel Sandbox metadata
SANDBOX_NAME_PREFIX=discord-
SANDBOX_TAG_APP=flue-discord-demo
SANDBOX_TAG_REPO=weather-starter
SANDBOX_TAG_LIFECYCLE=demo

# Placeholder response while real preview deployment is out of scope.
PLACEHOLDER_PREVIEW_URL=https://example.com/preview

# Cloudflare deployment configuration
# These are reference values for setup only.
CLOUDFLARE_ACCOUNT_ID=
CHAT_STATE_DO_BINDING=CHAT_STATE
WORKER_NAME=flue-discord-demo
