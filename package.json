{
  "name": "flue",
  "version": "1.0.0",
  "description": "Discord-to-Flue harness engineering demo prototype",
  "scripts": {
    "cf:dev": "wrangler dev --config apps/event-processor/wrangler.jsonc",
    "cf:deploy": "wrangler deploy --config apps/event-processor/wrangler.jsonc",
    "cf:dry-run": "wrangler deploy --dry-run --config apps/event-processor/wrangler.jsonc",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "cf:typegen": "cd apps/event-processor && wrangler types",
    "test": "node --import tsx --test apps/event-processor/src/**/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "tsx": "^4.21.0",
    "wrangler": "^4.90.0"
  },
  "dependencies": {
    "@chat-adapter/discord": "^4.28.1",
    "@flue/runtime": "^0.6.2",
    "@vercel/sandbox": "^2.0.0-beta.19",
    "chat": "^4.28.1",
    "chat-state-cloudflare-do": "^0.2.0"
  }
}
